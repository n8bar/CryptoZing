<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title }}</title>
  <meta name="description" content="{{ description }}">
  <meta name="theme-color" content="#111827">
  <link rel="icon" href="/favicon.ico" sizes="any">
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
  <link rel="manifest" href="/site.webmanifest">
  <link rel="canonical" href="{{ canonical }}">
  {% if noindex %}<meta name="robots" content="noindex, nofollow">{% endif %}
  <meta property="og:type" content="{{ og_type if og_type else 'website' }}">
  <meta property="og:url" content="{{ canonical }}">
  <meta property="og:title" content="{{ title }}">
  <meta property="og:description" content="{{ description }}">
  <meta property="og:image" content="{{ og_image if og_image else 'https://cryptozing.app/og-preview.png' }}">
  {% if og_image_width %}<meta property="og:image:width" content="{{ og_image_width }}">{% endif %}
  {% if og_image_height %}<meta property="og:image:height" content="{{ og_image_height }}">{% endif %}
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ title }}">
  <meta name="twitter:description" content="{{ description }}">
  <meta name="twitter:image" content="{{ og_image if og_image else 'https://cryptozing.app/og-preview.png' }}">
  <link rel="preconnect" href="https://fonts.bunny.net">
  <link href="https://fonts.bunny.net/css?family=instrument-sans:400,500,600,700" rel="stylesheet">
  <style>
    :root {
      --bg-base: #111827;
      --bg-overlay: linear-gradient(135deg, rgba(49, 46, 129, 0.88) 0%, #111827 46%, #020617 100%);
      --text-primary: #f8fafc;
      --text-secondary: #cbd5e1;
      --text-muted: #c7d2fe;
      --text-faint: #64748b;
      --button-bg: #4f46e5;
      --button-bg-hover: #6366f1;
      --button-text: #ffffff;
      --nav-border: rgba(255, 255, 255, 0.08);
      --prose-max: 62rem;
    }

    * { box-sizing: border-box; }
    html, body { margin: 0; height: 100%; }
    body {
      font-family: 'Instrument Sans', sans-serif;
      background: var(--bg-base);
      color: var(--text-primary);
      -webkit-font-smoothing: antialiased;
      text-rendering: optimizeLegibility;
      display: flex;
      flex-direction: column;
      height: 100vh;
      overflow: hidden;
    }

    .scroll-area {
      flex: 1;
      overflow-y: auto;
    }

    /* Nav */
    .site-nav {
      border-bottom: 1px solid var(--nav-border);
      flex-shrink: 0;
    }

    .nav-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1rem 1.5rem;
      max-width: 72rem;
      margin: 0 auto;
    }

    .nav-brand {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      text-decoration: none;
      color: var(--text-primary);
      font-weight: 700;
      font-size: 1.5rem;
      letter-spacing: 0.02em;
    }

    .nav-brand img { height: 3.5rem; width: auto; }

    .nav-links { display: flex; align-items: center; gap: 1.25rem; }

    .nav-links a {
      color: var(--text-secondary);
      text-decoration: none;
      font-size: 1.35rem;
      font-weight: 500;
      transition: color 140ms ease;
    }

    .nav-links a:hover { color: var(--text-primary); }

    /* Footer */
    .site-footer {
      border-top: 1px solid var(--nav-border);
      padding: 2rem 1.5rem;
      margin-top: 4rem;
      text-align: center;
      color: var(--text-faint);
      font-size: 1.21875rem;
    }

    .site-footer a {
      color: var(--text-muted);
      text-decoration: none;
    }

    .site-footer a:hover { text-decoration: underline; }

    /* Article prose */
    .article-wrap {
      max-width: var(--prose-max);
      margin: 3rem auto;
      padding: 0 1.5rem;
    }

    .article-wrap h1 {
      font-size: clamp(2.625rem, 6vw, 3.75rem);
      font-weight: 800;
      line-height: 1.1;
      letter-spacing: -0.03em;
      color: var(--text-primary);
      margin: 0 0 1.5rem;
    }

    .article-subtitle {
      font-size: 1.25rem;
      color: var(--text-muted);
      margin: -0.75rem 0 1.75rem;
      font-style: italic;
    }

    .article-meta {
      font-size: 1.1rem;
      color: var(--text-secondary);
      margin: -1rem 0 2rem;
      opacity: 0.7;
    }

    .article-wrap h2 {
      font-size: 2.25rem;
      font-weight: 700;
      color: var(--text-primary);
      margin: 2.5rem 0 0.75rem;
    }

    .article-wrap h3 {
      font-size: 1.625rem;
      font-weight: 700;
      color: var(--text-primary);
      margin: 2rem 0 0.5rem;
      text-decoration: underline;
      text-underline-offset: 0.3em;
    }

    .article-wrap p {
      font-size: 1.5rem;
      color: var(--text-secondary);
      line-height: 1.8;
      margin: 0 0 1.25rem;
    }

    .article-wrap ul, .article-wrap ol {
      font-size: 1.5rem;
      color: var(--text-secondary);
      line-height: 1.8;
      padding-left: 1.5rem;
      margin: 0 0 1.25rem;
    }

    .article-wrap li { margin-bottom: 0.4rem; }

    .article-wrap a {
      color: var(--text-muted);
      text-decoration: underline;
      text-underline-offset: 3px;
    }

    .article-wrap strong { color: var(--text-primary); }

    .article-wrap table {
      width: 100%;
      border-collapse: collapse;
      font-size: 1.1rem;
      margin: 2rem 0;
      overflow-x: auto;
      display: block;
    }

    .article-wrap thead {
      background: rgba(99, 102, 241, 0.15);
    }

    .article-wrap th {
      color: var(--text-primary);
      font-weight: 700;
      text-align: left;
      padding: 0.75rem 1rem;
      border-bottom: 2px solid rgba(99, 102, 241, 0.4);
      white-space: nowrap;
    }

    .article-wrap td {
      color: var(--text-secondary);
      padding: 0.6rem 1rem;
      border-bottom: 1px solid rgba(148, 163, 184, 0.15);
    }

    .article-wrap tbody tr:hover {
      background: rgba(99, 102, 241, 0.07);
    }

    .article-wrap td strong {
      color: var(--text-primary);
    }

    .article-back {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      color: var(--text-muted);
      text-decoration: none;
      font-size: 1.3125rem;
      font-weight: 600;
      margin-bottom: 2rem;
    }

    .article-back:hover { color: var(--text-primary); }

    /* Inline "watch the video" card: thumbnail linking to a video page. */
    a.video-link {
      display: flex;
      align-items: center;
      gap: 1.25rem;
      margin: 2.5rem 0;
      padding: 1rem;
      border-radius: 0.75rem;
      border: 1px solid rgba(255, 255, 255, 0.08);
      background: rgba(255, 255, 255, 0.03);
      text-decoration: none;
      transition: border-color 140ms ease, background 140ms ease;
    }

    a.video-link:hover {
      border-color: rgba(255, 255, 255, 0.16);
      background: rgba(255, 255, 255, 0.06);
    }

    .video-link-thumb {
      position: relative;
      flex: 0 0 12rem;
      width: 12rem;
      aspect-ratio: 16 / 9;
      border-radius: 0.5rem;
      overflow: hidden;
      background: #000;
    }

    .video-link-thumb img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .video-link-play {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: 2.75rem;
      height: 2.75rem;
      border-radius: 50%;
      background: rgba(17, 24, 39, 0.72);
      border: 2px solid rgba(255, 255, 255, 0.85);
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .video-link-play::after {
      content: '';
      margin-left: 0.18rem;
      border-style: solid;
      border-width: 0.45rem 0 0.45rem 0.78rem;
      border-color: transparent transparent transparent #ffffff;
    }

    .video-link-text {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
    }

    .video-link-kicker {
      text-transform: uppercase;
      letter-spacing: 0.08em;
      font-size: 0.95rem;
      font-weight: 700;
      color: var(--text-muted);
    }

    .video-link-title {
      font-size: 1.375rem;
      font-weight: 700;
      color: var(--text-primary);
      line-height: 1.3;
    }

    .video-link-meta {
      font-size: 1.05rem;
      color: var(--text-secondary);
      opacity: 0.75;
    }
  </style>
</head>
<body>
  {% if not hide_nav %}
  <nav class="site-nav">
    <div class="nav-inner">
      <a href="/" class="nav-brand">
        <img src="/images/CZ.png" alt="CryptoZing">
        CryptoZing
      </a>
      <div class="nav-links">
        <a href="/learn/">Guides</a>
        <a href="https://github.com/n8bar/CryptoZing" target="_blank" rel="noreferrer">GitHub</a>
      </div>
    </div>
  </nav>
  {% endif %}

  <div class="scroll-area">
    {{ content | safe }}

    {% if not hide_footer %}
    <footer class="site-footer">
      <p>CryptoZing &mdash; Bitcoin invoicing for humans. &nbsp;<a href="https://github.com/n8bar/CryptoZing" target="_blank" rel="noreferrer">Follow development on GitHub</a></p>
    </footer>
    {% endif %}
  </div>
</body>
</html>
