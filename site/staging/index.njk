---
layout: default.njk
title: "Staging"
description: "Staged content awaiting review."
canonical: "https://cryptozing.app/staging/"
noindex: true
eleventyExcludeFromCollections: true
---
<style>
  .staging-wrap {
    max-width: var(--prose-max);
    margin: 3rem auto;
    padding: 0 1.5rem;
  }

  .staging-wrap h1 {
    font-size: clamp(2.25rem, 5vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--text-primary);
    margin: 0 0 0.75rem;
  }

  .staging-intro {
    font-size: 1.25rem;
    color: var(--text-secondary);
    line-height: 1.75;
    margin: 0 0 3rem;
    max-width: 52rem;
  }

  .article-list {
    display: grid;
    gap: 1rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .article-card {
    position: relative;
    padding: 1.5rem;
    border-radius: 0.75rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.03);
    transition: border-color 140ms ease, background 140ms ease;
  }

  .article-card:hover {
    border-color: rgba(255, 255, 255, 0.16);
    background: rgba(255, 255, 255, 0.06);
  }

  .article-card h2 {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0 0 0.4rem;
  }

  .article-card h2 a {
    color: inherit;
    text-decoration: none;
  }

  .article-card h2 a::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 0.75rem;
  }

  .article-card-meta {
    font-size: 0.95rem;
    color: var(--text-secondary);
    opacity: 0.6;
    margin: 0 0 0.5rem;
  }

  .article-card p {
    font-size: 1.125rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 0;
  }
</style>

<div class="staging-wrap">
  <h1>Staging</h1>
  <p class="staging-intro">Content staged for review. Nothing here is published or indexed.</p>

  <ul class="article-list">
    {% for post in collections.staging | reverse %}
    <li>
      <article class="article-card">
        <h2><a href="{{ post.url }}">{{ post.data.title }}</a></h2>
        {% if post.data.author or post.data.date %}<p class="article-card-meta">{% if post.data.author %}{{ post.data.author }}{% endif %}{% if post.data.author and post.data.date %} · {% endif %}{% if post.data.date %}{{ post.data.date | date("%B %d, %Y") }}{% endif %}</p>{% endif %}
        <p>{{ post.data.description }}</p>
      </article>
    </li>
    {% endfor %}
  </ul>
</div>
