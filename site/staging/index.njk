---
layout: default.njk
title: "Staging"
description: "Staged content awaiting review."
canonical: "https://cryptozing.app/staging/"
noindex: true
eleventyExcludeFromCollections: true
---
<style>
  .staging-wrap {
    max-width: var(--prose-max);
    margin: 3rem auto;
    padding: 0 1.5rem;
  }

  .staging-wrap h1 {
    font-size: clamp(2.25rem, 5vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--text-primary);
    margin: 0 0 0.75rem;
  }

  .staging-intro {
    font-size: 1.25rem;
    color: var(--text-secondary);
    line-height: 1.75;
    margin: 0 0 3rem;
    max-width: 52rem;
  }

  .article-list {
    display: grid;
    gap: 1rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .article-card {
    position: relative;
    padding: 1.5rem;
    border-radius: 0.75rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.03);
    transition: border-color 140ms ease, background 140ms ease;
  }

  .article-card:hover {
    border-color: rgba(255, 255, 255, 0.16);
    background: rgba(255, 255, 255, 0.06);
  }

  .article-card h2 {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0 0 0.4rem;
  }

  .article-card h2 a {
    color: inherit;
    text-decoration: none;
  }

  .article-card h2 a::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 0.75rem;
    z-index: 1;
  }

  .article-card--media {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .article-card-thumb {
    position: relative;
    flex: 0 0 8.5rem;
    width: 8.5rem;
    aspect-ratio: 16 / 9;
    border-radius: 0.5rem;
    overflow: hidden;
    background: #000;
  }

  .article-card-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .article-card-play {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    background: rgba(17, 24, 39, 0.72);
    border: 1.5px solid rgba(255, 255, 255, 0.85);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .article-card-play::after {
    content: '';
    margin-left: 0.12rem;
    border-style: solid;
    border-width: 0.32rem 0 0.32rem 0.55rem;
    border-color: transparent transparent transparent #ffffff;
  }

  .article-card-body { min-width: 0; }

  .article-card-meta {
    font-size: 0.95rem;
    color: var(--text-secondary);
    opacity: 0.6;
    margin: 0 0 0.5rem;
  }

  .article-card p {
    font-size: 1.125rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 0;
  }
</style>

<div class="staging-wrap">
  <h1>Staging</h1>
  <p class="staging-intro">Content staged for review. Nothing here is published or indexed.</p>

  <ul class="article-list">
    {% for post in collections.stagingList %}
    <li>
      <article class="article-card{% if post.data.card_image %} article-card--media{% endif %}">
        {% if post.data.card_image %}
        <span class="article-card-thumb">
          <img src="{{ post.data.card_image }}" alt="" loading="lazy">
          <span class="article-card-play" aria-hidden="true"></span>
        </span>
        <div class="article-card-body">
          <h2><a href="{{ post.url }}">{{ post.data.title }}</a></h2>
          {% if post.data.author or post.data.date %}<p class="article-card-meta">{% if post.data.author %}{{ post.data.author }}{% endif %}{% if post.data.author and post.data.date %} · {% endif %}{% if post.data.date %}{{ post.data.date | date("%B %d, %Y") }}{% endif %}</p>{% endif %}
          <p>{{ post.data.description }}</p>
        </div>
        {% else %}
        <h2><a href="{{ post.url }}">{{ post.data.title }}</a></h2>
        {% if post.data.author or post.data.date %}<p class="article-card-meta">{% if post.data.author %}{{ post.data.author }}{% endif %}{% if post.data.author and post.data.date %} · {% endif %}{% if post.data.date %}{{ post.data.date | date("%B %d, %Y") }}{% endif %}</p>{% endif %}
        <p>{{ post.data.description }}</p>
        {% endif %}
      </article>
    </li>
    {% endfor %}
  </ul>
</div>
